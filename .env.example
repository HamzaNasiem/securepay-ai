# SecurePay AI — Environment Configuration
# Copy this file to .env and fill in your Fireworks API key.
# Get your API key from: https://fireworks.ai/

# ──────────────────────────────────────────────────────────────────────────────
# Fireworks AI Configuration (Google Gemma 3 27B on AMD Instinct MI300X)
# Primary model: Google Gemma 3 27B IT — runs on AMD MI300X GPUs via Fireworks AI
# Fallback model: DeepSeek V4 Pro (automatically used if Gemma is unavailable)
# ──────────────────────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=your_fireworks_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/gemma-3-27b-it

# Alternative: DeepSeek V4 Pro (AMD-accelerated)
# FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro

# ──────────────────────────────────────────────────────────────────────────────
# Redis Configuration
# Local dev: redis://localhost:6379  |  Docker: redis://redis:6379
# ──────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────────────────
# Cryptographic Vault Configuration
# VAULT_ENCRYPTION_KEY: Exactly 32 ASCII characters for AES-256-GCM.
# DO NOT share or commit this key in production environments.
# ──────────────────────────────────────────────────────────────────────────────
VAULT_ENCRYPTION_KEY=replace_with_exactly_32_characters!!
VAULT_DB_PATH=vault.db

# ──────────────────────────────────────────────────────────────────────────────
# Frontend CORS Configuration
# ──────────────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
