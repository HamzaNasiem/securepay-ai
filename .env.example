# SecurePay AI — Environment Configuration
# Copy this file to .env and fill in your Fireworks API key.

# Fireworks AI Configuration (Google Gemma 2 on AMD Hardware)
FIREWORKS_API_KEY=your_fireworks_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro

# Redis Configuration (Local dev default: localhost:6379, Docker default: redis:6379)
REDIS_URL=redis://localhost:6379

# Cryptographic Vault Configuration
# Must be a 32-character key for AES-256-GCM. DO NOT share this in production.
VAULT_ENCRYPTION_KEY=replace_with_exactly_32_characters!!
VAULT_DB_PATH=vault.db

# Frontend CORS Configuration (Optional)
FRONTEND_ORIGIN=http://localhost:5173
